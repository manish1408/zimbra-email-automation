# Zimbra server URLs (no trailing slash)
ZIMBRA_HOST=mail.example.com
ZIMBRA_ADMIN_PORT=7071
ZIMBRA_MAIL_PORT=443
ZIMBRA_USE_HTTPS=true
ZIMBRA_VERIFY_SSL=false

# Admin credentials
ZIMBRA_ADMIN_USER=admin@example.com
ZIMBRA_ADMIN_PASSWORD=your-admin-password

# Optional: limit sync to a single domain (e.g. example.com)
ZIMBRA_DOMAIN_FILTER=

# Email search defaults
ZIMBRA_SEARCH_QUERY=is:anywhere
ZIMBRA_SEARCH_BATCH_SIZE=100

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# LangGraph agent (LLM)
# Provider: vastai | openai
LLM_PROVIDER=vastai

# Vast.ai / Ollama-compatible endpoint (/api/generate)
VASTAI_BASE_URL=https://seven-executives-reception-compressed.trycloudflare.com
VASTAI_TOKEN=your-vast-ai-token
VASTAI_MODEL=qwen3.5:35b
VASTAI_COOKIE_NAME=C.39613280_auth_token
VASTAI_TIMEOUT_SECONDS=300

# OpenAI (only when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
AGENT_INBOX_LIMIT=10
AGENT_CHECKPOINT_PATH=data/agent_checkpoints.db

# Scheduled sync + AI analysis (mail_poller.py or scheduled_job.py)
SYNC_TARGET_EMAIL=user@example.com
SYNC_INTERVAL_HOURS=6
DATABASE_URL=sqlite:///data/emails.db
SYNC_FETCH_BODIES=true
SYNC_POLL_INTERVAL_SECONDS=60
SYNC_INBOX_QUERY=in:inbox
SYNC_OVERLAP_MINUTES=5

# Automation actions (classify emails and move to category folders on Zimbra)
# Set AUTOMATION_DRY_RUN=false to apply real Zimbra moves, forwards, and acks
AUTOMATION_DRY_RUN=true
AUTOMATION_MOVE_TO_FOLDERS=true
AUTO_SEND_ACK=true
ROUTING_RULES_PATH=config/routing_rules.yaml
EMPLOYEES_PATH=config/employees.yaml
