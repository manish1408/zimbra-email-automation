# Zimbra server URLs (no trailing slash)
ZIMBRA_HOST=mail.example.com
ZIMBRA_ADMIN_PORT=7071
ZIMBRA_MAIL_PORT=443
ZIMBRA_USE_HTTPS=true
ZIMBRA_VERIFY_SSL=false

# Admin credentials
ZIMBRA_ADMIN_USER=admin@example.com
ZIMBRA_ADMIN_PASSWORD=your-admin-password

# Optional: limit sync to a single domain (e.g. example.com)
ZIMBRA_DOMAIN_FILTER=

# Email search defaults
ZIMBRA_SEARCH_QUERY=in:anywhere
ZIMBRA_SEARCH_BATCH_SIZE=100

# App
APP_HOST=0.0.0.0
APP_PORT=8000

# LangGraph agent (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
AGENT_INBOX_LIMIT=10
AGENT_CHECKPOINT_PATH=data/agent_checkpoints.db
